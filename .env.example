# 复制为 .env 后按需填写。不要在版本库中提交真实 .env。

# ---------- 大模型（分析节点） ----------
GLM_API_KEY=
GLM_BASE_URL=
GLM_MODEL=

# ---------- 数据库 ----------
# local = SQLite（默认）；其他值 = PostgreSQL（需配置 DB_* 并已建表）
DB_MODE=local
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=langchain_db
# DB_USER=postgres
# DB_PASSWORD=

# ---------- HTTP 服务（可选，用于简化启动：python run_server.py）----------
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=true
